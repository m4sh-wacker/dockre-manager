# JWT secret used to sign auth tokens (Go backend)
JWT_SECRET=change-me-to-a-random-secret

# MySQL connection (Go backend). Prisma-style URL is auto-converted.
DATABASE_URL="mysql://root:@127.0.0.1:3306/docker_manager"

# Directory containing deployable templates (relative to the Go binary)
TEMPLATE_DIR=../../templates

# Go backend port
PORT=3030

# Frontend → backend base URL
NEXT_PUBLIC_API_URL=http://localhost:3030
